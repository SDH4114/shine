; Comments and strings are deliberately distinct so source stays easy to scan.
(comment) @comment
(string) @string
(number) @number
(boolean) @boolean
(keyword) @keyword
(builtin) @function.builtin
(type) @type.builtin
(operator) @operator
(left_paren) @punctuation.bracket
(right_paren) @punctuation.bracket
(left_bracket) @punctuation.bracket
(right_bracket) @punctuation.bracket
(left_brace) @punctuation.bracket
(right_brace) @punctuation.bracket
(punctuation) @punctuation
(identifier) @variable
